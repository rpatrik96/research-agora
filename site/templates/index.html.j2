<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Research Agora — AI Skills for Research</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <nav class="site-nav">
        <div class="container nav-container">
            <a href="index.html" class="nav-brand">Research Agora</a>
            <div class="nav-links">
                <a href="index.html" class="nav-link active">Skills</a>
                <a href="benchmarks.html" class="nav-link">Benchmarks</a>
                <a href="docs.html" class="nav-link">Docs</a>
            </div>
        </div>
    </nav>

    <header>
        <div class="container">
            <h1>Research Agora</h1>
            <p class="subtitle">AI-powered skills for every stage of ML research</p>
            <div class="stats">
                <span class="stat"><strong>{{ stats.public_skills }}</strong> skills</span>
                <span class="stat"><strong>{{ stats.groups }}</strong> workflows</span>
                <span class="stat"><strong>{{ stats.plugins }}</strong> plugins</span>
                <span class="stat"><strong>{{ stats.benchmarks }}</strong> benchmarks</span>
            </div>
            <div class="install-banner">
                <code>/plugin marketplace add rpatrik96/research-agora</code>
                <button onclick="navigator.clipboard.writeText('/plugin marketplace add rpatrik96/research-agora')" title="Copy to clipboard" aria-label="Copy install command">Copy</button>
            </div>
        </div>
    </header>

    <section class="intent-section container">
        <div class="intent-buttons">
            <button class="intent-btn" data-groups="paper-drafting,writing-polish,literature-discovery">I'm writing a paper</button>
            <button class="intent-btn" data-groups="quality-verification,theory-tools">Verify my paper</button>
            <button class="intent-btn" data-groups="dissemination,documents-figures,submission-rebuttal">Present &amp; share</button>
            <button class="intent-btn intent-btn-all active" data-groups="all">Browse all</button>
        </div>
    </section>

    <main class="container">
        <div class="layout">
            <aside class="filters">
                <h2>Filters</h2>

                <div class="search-box">
                    <input type="text" id="search" placeholder="Search skills..." aria-label="Search skills">
                </div>

                <details open>
                    <summary>Plugin</summary>
                    <div class="filter-group" data-filter="plugin">
                        {% for p in plugins %}
                        <label><input type="checkbox" value="{{ p }}" checked> {{ p }}</label>
                        {% endfor %}
                    </div>
                </details>

                <details>
                    <summary>Task Type</summary>
                    <div class="filter-group" data-filter="task-type">
                        {% for t in task_types %}
                        <label><input type="checkbox" value="{{ t }}" checked> {{ t }}</label>
                        {% endfor %}
                    </div>
                </details>

                <details>
                    <summary>Verification Level</summary>
                    <div class="filter-group" data-filter="verification">
                        {% for v in verification_levels %}
                        <label><input type="checkbox" value="{{ v }}" checked> {{ v }}</label>
                        {% endfor %}
                    </div>
                </details>

                <div class="internal-toggle">
                    <label><input type="checkbox" id="show-internal"> Show internal/developer skills ({{ internal_skills|length }})</label>
                </div>

                <button id="reset-filters" class="reset-btn">Reset All Filters</button>
            </aside>

            <section class="skills-content" id="skills-content">
                <p class="results-count" id="results-count">Showing {{ stats.public_skills }} skills</p>

                {% for group_id, group_data in grouped_skills.items() %}
                <details class="skill-group" open data-group="{{ group_id }}">
                    <summary class="group-header">
                        <h2 class="group-title">{{ group_data.label }}</h2>
                        <span class="group-count">{{ group_data.skills|length }}</span>
                        <p class="group-desc">{{ group_data.description }}</p>
                    </summary>
                    <div class="group-grid">
                        {% for skill in group_data.skills %}
                        <article class="skill-card"
                            data-plugin="{{ skill.plugin }}"
                            data-task-type="{{ skill['task-type'] }}"
                            data-verification="{{ skill['verification-level'] }}"
                            data-visibility="{{ skill.get('visibility', 'public') }}"
                            data-name="{{ skill.name }}"
                            data-description="{{ skill.description }}">

                            <div class="card-header">
                                <h3>{{ skill.name }}</h3>
                                <span class="badge badge-plugin">{{ skill.plugin }}</span>
                            </div>

                            <div class="card-description">
                                {% if skill.description|length > 150 %}
                                <p class="desc-short">{{ skill.description[:150] }}...<button class="desc-toggle" aria-label="Show full description">more</button></p>
                                <p class="desc-full hidden">{{ skill.description }}<button class="desc-toggle" aria-label="Collapse description">less</button></p>
                                {% else %}
                                <p>{{ skill.description }}</p>
                                {% endif %}
                            </div>

                            <div class="card-meta">
                                <span class="badge {{ skill['verification-level']|verification_badge }}">{{ skill['verification-level'] }}</span>
                                <span class="badge {{ skill.model|model_badge }}">{{ skill.model }}</span>
                            </div>

                            <div class="card-actions">
                                <code class="install-cmd">/{{ skill.name }}</code>
                                <a href="{{ skill.source_url }}" target="_blank" rel="noopener" class="source-link">Source</a>
                            </div>
                        </article>
                        {% endfor %}
                    </div>
                </details>
                {% endfor %}

                <!-- Internal skills section (hidden by default) -->
                <div id="internal-section" class="internal-section hidden">
                    <h2 class="internal-heading">Internal / Developer Skills</h2>
                    <p class="internal-desc">These are building blocks used internally by other skills. Most users won't need to invoke them directly.</p>
                    <div class="group-grid">
                        {% for skill in internal_skills %}
                        <article class="skill-card skill-card-internal"
                            data-plugin="{{ skill.plugin }}"
                            data-task-type="{{ skill['task-type'] }}"
                            data-verification="{{ skill['verification-level'] }}"
                            data-visibility="internal"
                            data-name="{{ skill.name }}"
                            data-description="{{ skill.description }}">

                            <div class="card-header">
                                <h3>{{ skill.name }}</h3>
                                <span class="badge badge-type">{{ skill.type }}</span>
                            </div>

                            <div class="card-description">
                                {% if skill.description|length > 150 %}
                                <p class="desc-short">{{ skill.description[:150] }}...<button class="desc-toggle" aria-label="Show full description">more</button></p>
                                <p class="desc-full hidden">{{ skill.description }}<button class="desc-toggle" aria-label="Collapse description">less</button></p>
                                {% else %}
                                <p>{{ skill.description }}</p>
                                {% endif %}
                            </div>

                            <div class="card-meta">
                                <span class="badge {{ skill['verification-level']|verification_badge }}">{{ skill['verification-level'] }}</span>
                                <span class="badge {{ skill.model|model_badge }}">{{ skill.model }}</span>
                            </div>

                            <div class="card-actions">
                                <code class="install-cmd">{{ skill.type }}: {{ skill.name }}</code>
                                <a href="{{ skill.source_url }}" target="_blank" rel="noopener" class="source-link">Source</a>
                            </div>
                        </article>
                        {% endfor %}
                    </div>
                </div>
            </section>
        </div>
    </main>

    <footer class="container">
        <p>
            <a href="https://github.com/rpatrik96/research-agora">GitHub</a> |
            <a href="https://github.com/rpatrik96/research-agora/blob/main/CONTRIBUTING.md">Contribute</a> |
            <a href="https://github.com/rpatrik96/research-agora/blob/main/INTEROP.md">Interop</a> |
            <a href="https://github.com/rpatrik96/research-agora/blob/main/PLATFORM.md">Platform Design</a>
        </p>
        <p class="generated">Generated {{ generated }}</p>
    </footer>

    <script src="search.js"></script>
</body>
</html>
