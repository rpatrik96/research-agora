{
  "name": "research-agents",
  "description": "Specialized research analysis agents for critical thinking, evidence verification, synthesis, and parallel paper analysis",
  "version": "2.0.0",
  "author": {
    "name": "rpatrik96",
    "email": "rpatrik96@gmail.com"
  },
  "homepage": "https://github.com/rpatrik96/research-agora",
  "repository": "https://github.com/rpatrik96/research-agora",
  "license": "MIT",
  "keywords": [
    "research",
    "agents",
    "critical-thinking",
    "analysis",
    "verification",
    "parallel",
    "claims",
    "evidence",
    "proofs",
    "theoretical",
    "mathematical"
  ],
  "components": {
    "agents": {
      "description": "High-level research analysis agents",
      "items": [
        "claim-auditor",
        "devils-advocate",
        "perspective-synthesizer",
        "audience-checker",
        "figure-storyteller",
        "latex-debugger",
        "statistical-validator",
        "artifact-packager",
        "reviewer-response-generator",
        "state-generator",
        "proof-auditor",
        "bounds-analyst",
        "notation-consistency-checker",
        "theorem-dependency-mapper",
        "proof-strategy-advisor",
        "counterexample-searcher",
        "intuition-formalizer",
        "theory-connector",
        "content-archaeologist",
        "voice-drift-detector",
        "redundancy-radar",
        "reader-simulation"
      ]
    },
    "micro-skills": {
      "description": "Atomic, parallelizable operations for paper analysis",
      "items": [
        "claim-extractor",
        "claim-classifier",
        "evidence-locator",
        "evidence-grader",
        "novelty-checker",
        "citation-verifier",
        "assumption-surfacer",
        "cross-referencer",
        "proof-step-extractor",
        "proof-step-verifier",
        "assumption-analyzer",
        "derivation-checker"
      ]
    },
    "orchestrators": {
      "description": "Parallel workflow coordinators",
      "items": [
        "parallel-audit",
        "parallel-review",
        "parallel-theory-audit",
        "pre-submission-audit"
      ]
    },
    "helpers": {
      "description": "Utility skills for efficiency",
      "items": [
        "batch-arxiv",
        "prefetch-evidence",
        "context-compactor"
      ]
    }
  },
  "features": {
    "parallel_execution": {
      "description": "Fan-out/fan-in pattern for 2-3x speedup on large papers",
      "enabled": true
    },
    "research_state": {
      "description": "Structured JSON intermediate representation for caching",
      "schema": "schemas/research-state.schema.json"
    },
    "evidence_hierarchy": {
      "description": "L1-L6 evidence grading with venue-specific standards",
      "levels": ["CODE_VERIFIED", "REPRODUCIBLE_EXPERIMENT", "PAPER_EVIDENCE", "CITATION_SUPPORT", "LOGICAL_ARGUMENT", "ASSERTION"]
    },
    "theoretical_evidence_hierarchy": {
      "description": "T1-T6 theoretical proof grading for mathematical papers",
      "levels": ["FORMALLY_VERIFIED", "COMPLETE_PROOF", "PROOF_WITH_GAPS", "PROOF_SKETCH", "INFORMAL_ARGUMENT", "THEOREM_ASSERTION"]
    }
  }
}
